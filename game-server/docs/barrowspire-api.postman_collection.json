              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"upload_id\": \"upload-123-xyz\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/member/avatar/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "member", "avatar", "confirm"]
            },
            "description": "Confirm avatar upload completion (requires authentication)"
          }
        }
      ]
    },
    {
