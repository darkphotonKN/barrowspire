{
  "info": {
    "name": "The Era of Barrowspire API",
    "description": "API collection for The Era of Barrowspire - 2D Multiplayer Game Server",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "member_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth & Members",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/member/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "member", "signup"]
            },
            "description": "Create a new member account (via RabbitMQ RPC)"
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the response body",
                  "const response = pm.response.json();",
                  "",
                  "// Check if the request was successful",
                  "if (pm.response.code === 200 && response.result) {",
                  "    // Extract the tokens from the response",
                  "    const accessToken = response.result.access_token;",
                  "    const refreshToken = response.result.refresh_token;",
                  "    const memberId = response.result.member_info?.id;",
                  "    ",
                  "    // Set the tokens as environment/collection variables",
                  "    if (accessToken) {",
                  "        pm.collectionVariables.set('access_token', accessToken);",
                  "        console.log('Access token saved:', accessToken);",
                  "    }",
                  "    ",
                  "    if (refreshToken) {",
                  "        pm.collectionVariables.set('refresh_token', refreshToken);",
                  "        console.log('Refresh token saved');",
                  "    }",
                  "    ",
                  "    if (memberId) {",
                  "        pm.collectionVariables.set('member_id', memberId);",
                  "        console.log('Member ID saved:', memberId);",
                  "    }",
                  "    ",
                  "    // Log success",
                  "    console.log('Login successful! Tokens have been saved to collection variables.');",
                  "} else {",
                  "    console.log('Login failed. Please check your credentials.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/member/signin",
              "host": ["{{base_url}}"],
              "path": ["api", "member", "signin"]
            },
            "description": "Login member and get access token (via RabbitMQ RPC). This will automatically save the access_token, refresh_token, and member_id to collection variables."
          }
        },
        {
          "name": "Get Member Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/member",
              "host": ["{{base_url}}"],
              "path": ["api", "member"]
            },
            "description": "Get current member information (requires authentication)"
          }
        },
        {
