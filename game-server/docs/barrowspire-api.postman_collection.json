            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"OldPassword123!\",\n  \"new_password\": \"NewPassword456!\",\n  \"repeat_new_password\": \"NewPassword456!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/member/update-password",
              "host": ["{{base_url}}"],
              "path": ["api", "member", "update-password"]
            },
            "description": "Update member password (requires authentication)"
          }
        },
        {
          "name": "Update Member Info",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
