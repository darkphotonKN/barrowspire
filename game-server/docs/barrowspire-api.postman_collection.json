            "description": "Request a pre-signed URL for avatar upload (requires authentication)"
          }
        },
        {
          "name": "Confirm Avatar Upload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
