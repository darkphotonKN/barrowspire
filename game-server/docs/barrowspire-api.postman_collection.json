              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/member/update-info",
              "host": ["{{base_url}}"],
              "path": ["api", "member", "update-info"]
            },
            "description": "Update member information (requires authentication)"
          }
        },
        {
          "name": "Request Avatar Upload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/member/avatar/upload-request",
              "host": ["{{base_url}}"],
              "path": ["api", "member", "avatar", "upload-request"]
